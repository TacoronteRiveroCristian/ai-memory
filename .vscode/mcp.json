{
    "inputs": [
        {
            "type": "promptString",
            "id": "memory-api-key",
            "description": "AI Memory API key",
            "password": true
        }
    ],
    "servers": {
        "memoryBrain": {
            "type": "http",
            "url": "http://localhost:8050/mcp",
            "headers": {
                "X-API-Key": "${input:memory-api-key}"
            }
        },
        "oraios/serena": {
            "type": "stdio",
            "command": "uvx",
            "args": [
                "-p",
                "3.13",
                "--from",
                "git+https://github.com/oraios/serena",
                "serena",
                "start-mcp-server",
                "--context",
                "ide",
                "--project",
                "${workspaceFolder}"
            ]
        }
    },
}
